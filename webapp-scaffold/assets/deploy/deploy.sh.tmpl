#!/usr/bin/env bash
# __APP_NAME__ Deploy (LXC, Debian) — idempotent, re-runnable.
# Generiert vom webapp-scaffold-Skill. Voraussetzung auf dem Container:
# Node 22 + pnpm (corepack), nginx. Bei KB: PostgreSQL + pgvector/pg_trgm + Python3-venv.
#
# Aufruf auf dem LXC (root):  bash /opt/__APP_NAME__/scripts/deploy.sh
set -euo pipefail

APP_DIR=/opt/__APP_NAME__
PORT=__PORT__
WITH_KB=__WITH_KB__              # "1" = KB-Modul aktiv (pgvector + Embedding-Service + Ingest)
EMBED_VENV=/opt/__APP_NAME__-embedding
DB_NAME=__DB_NAME__
DB_USER=__DB_USER__
DB_PASS="${__APP_ENV___DB_PASS:-__DB_USER__}"

echo "==> [1/N] Code aktualisieren ($APP_DIR)"
# FAIL-LOUD: Ein Nicht-git-Checkout (z.B. rsync-deployt) würde sonst LAUTLOS übersprungen
# → deploy.sh baut+restartet STALE-Code und meldet trotzdem „fertig". Lieber hart abbrechen
# mit Konvertierungs-Anleitung als still das Falsche deployen. (Fleet-Lehre law-master 2026-06-04)
if [ ! -d "$APP_DIR/.git" ]; then
  echo "FATAL: $APP_DIR ist KEIN git-Checkout (.git fehlt)." >&2
  echo "       Ohne git kann deploy.sh den Code nicht aktualisieren → es würde STALE-Code bauen." >&2
  echo "       In echten SSH-git-Checkout konvertieren (Produkt-Repos sind privat → SSH-Key nötig):" >&2
  echo "         cd $APP_DIR" >&2
  echo "         git init && git remote add origin git@github.com:meintechblog/__APP_NAME__.git" >&2
  echo "         git config --global --add safe.directory $APP_DIR" >&2
  echo "         git fetch origin main && git reset --hard origin/main" >&2
  echo "       (LXC braucht ~/.ssh/id_ed25519 mit Repo-Scope; HTTPS scheitert bei privaten Repos.)" >&2
  exit 1
fi
git -C "$APP_DIR" fetch --all -q && git -C "$APP_DIR" reset --hard origin/main
cd "$APP_DIR"

if [ "$WITH_KB" = "1" ]; then
  echo "==> [KB] PostgreSQL: Rolle + DB + Schema + Rechte"
  sudo -u postgres psql -tc "SELECT 1 FROM pg_roles WHERE rolname='$DB_USER'" | grep -q 1 || \
    sudo -u postgres psql -c "CREATE ROLE $DB_USER LOGIN PASSWORD '$DB_PASS';"
  sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname='$DB_NAME'" | grep -q 1 || \
    sudo -u postgres createdb -O "$DB_USER" "$DB_NAME"
  sudo -u postgres psql -d "$DB_NAME" -c "CREATE EXTENSION IF NOT EXISTS vector; CREATE EXTENSION IF NOT EXISTS pg_trgm;"
  sudo -u postgres psql -d "$DB_NAME" -f "$APP_DIR/scripts/schema.sql"
  # Schema wird als postgres geladen → Tabellen gehören postgres. App-Rolle braucht Rechte.
  sudo -u postgres psql -d "$DB_NAME" <<SQL
GRANT USAGE, CREATE ON SCHEMA public TO $DB_USER;
GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO $DB_USER;
GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT USAGE, SELECT ON SEQUENCES TO $DB_USER;
SQL

  echo "==> [KB] Embedding-Service venv + systemd"
  if [ ! -d "$EMBED_VENV" ]; then python3 -m venv "$EMBED_VENV"; fi
  "$EMBED_VENV/bin/pip" install -q --upgrade pip
  "$EMBED_VENV/bin/pip" install -q -r "$APP_DIR/scripts/requirements.txt"
  cp "$APP_DIR/scripts/__APP_NAME__-embedding.service" /etc/systemd/system/
  systemctl daemon-reload
  systemctl enable --now __APP_NAME__-embedding.service
  systemctl enable postgresql 2>/dev/null || true   # DB nach Backup-Reboot (Proxmox stop-mode) automatisch hochfahren
  for i in $(seq 1 60); do curl -sf http://127.0.0.1:__EMBED_PORT__/health >/dev/null && break; sleep 2; done
fi

echo "==> Next.js build (standalone)"
if [ "$WITH_KB" = "1" ]; then
  export DATABASE_URL="postgres://$DB_USER:$DB_PASS@127.0.0.1:5432/$DB_NAME"
  export EMBED_URL="http://127.0.0.1:__EMBED_PORT__"
fi
corepack pnpm install --frozen-lockfile
corepack pnpm build
cp -r "$APP_DIR/.next/static" "$APP_DIR/.next/standalone/.next/static"
[ -d "$APP_DIR/public" ] && cp -r "$APP_DIR/public" "$APP_DIR/.next/standalone/public" || true

if [ "$WITH_KB" = "1" ]; then
  echo "==> [KB] Content ingesten"
  DATABASE_URL="$DATABASE_URL" EMBED_URL="$EMBED_URL" \
    "$EMBED_VENV/bin/python" "$APP_DIR/scripts/ingest.py" --content "$APP_DIR/content" --prune
fi

echo "==> App-Service + nginx"
cp "$APP_DIR/scripts/__APP_NAME__.service" /etc/systemd/system/
systemctl daemon-reload
systemctl enable --now __APP_NAME__.service
systemctl restart __APP_NAME__.service
cp "$APP_DIR/scripts/nginx-__APP_NAME__.conf" /etc/nginx/sites-available/__APP_NAME__
ln -sf /etc/nginx/sites-available/__APP_NAME__ /etc/nginx/sites-enabled/__APP_NAME__
rm -f /etc/nginx/sites-enabled/default
nginx -t && systemctl reload nginx
systemctl enable nginx 2>/dev/null || true   # nginx nach Backup-Reboot (Proxmox stop-mode) automatisch hochfahren

echo "==> Fertig. http://$(hostname -I | awk '{print $1}')/"
