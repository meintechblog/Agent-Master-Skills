import { fetchOpenItems, type GithubItem } from "@/lib/github";

export const dynamic = "force-dynamic";

function fmtDate(iso: string): string {
  try {
    return new Date(iso).toLocaleDateString("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" });
  } catch {
    return iso;
  }
}

function ItemList({ items, kind }: { items: GithubItem[]; kind: string }) {
  if (!items.length) {
    return <p style={{ color: "var(--faint)", fontSize: 14 }}>Keine offenen {kind}.</p>;
  }
  return (
    <ul style={{ listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: 8 }}>
      {items.map((it) => (
        <li
          key={it.number}
          style={{ border: "1px solid var(--border)", borderRadius: 9, padding: "10px 13px" }}
        >
          <a href={it.url} target="_blank" rel="noopener noreferrer" style={{ color: "var(--accent)", fontWeight: 600, textDecoration: "none" }}>
            #{it.number} {it.title}
          </a>
          <div style={{ color: "var(--faint)", fontSize: 12.5, marginTop: 3 }}>
            @{it.author} · {fmtDate(it.created_at)}
          </div>
        </li>
      ))}
    </ul>
  );
}

export default async function GithubPage() {
  const data = await fetchOpenItems();
  return (
    <main style={{ padding: "2rem 0" }}>
      <h1 style={{ fontSize: "1.7rem", fontWeight: 750, letterSpacing: "-0.025em", margin: "0 0 0.3rem" }}>
        GitHub
      </h1>
      <p style={{ color: "var(--muted)", fontSize: 14, margin: "0 0 1.4rem" }}>
        Offene Issues &amp; Pull Requests{data.repo ? ` · ${data.repo}` : ""}
      </p>

      {data.error ? (
        <div style={{ border: "1px solid var(--border)", borderRadius: 9, padding: "12px 14px", color: "var(--muted)", fontSize: 14 }}>
          {data.error}
        </div>
      ) : (
        <div style={{ display: "flex", flexDirection: "column", gap: "1.8rem" }}>
          <section>
            <h2 style={{ fontSize: "1.05rem", fontWeight: 650, margin: "0 0 0.7rem" }}>
              Issues <span style={{ color: "var(--faint)", fontWeight: 400 }}>({data.issues.length})</span>
            </h2>
            <ItemList items={data.issues} kind="Issues" />
          </section>
          <section>
            <h2 style={{ fontSize: "1.05rem", fontWeight: 650, margin: "0 0 0.7rem" }}>
              Pull Requests <span style={{ color: "var(--faint)", fontWeight: 400 }}>({data.prs.length})</span>
            </h2>
            <ItemList items={data.prs} kind="Pull Requests" />
          </section>
        </div>
      )}
    </main>
  );
}
